generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionTier {
  FREE
  PRO
  PRO_PLUS
}

model ValuationRequest {
  id              String   @id @default(cuid())
  requestNumber   Int      @default(autoincrement())
  createdAt       DateTime @default(now())
  
  // Konum Bilgileri
  city            String
  district        String
  neighborhood    String
  
  // Bina & Kat Bilgileri
  buildingAge     Int
  totalFloors     Int
  floor           String
  
  // İç Mekan Özellikleri
  rooms           String   // Örn: "1+1", "2+1", "3+1" vb.
  netSqm          Int
  grossSqm        Int
  kitchenType     String   // "Açık", "Kapalı"
  bathrooms       Int
  hasBalcony      Boolean
  
  // Ekstralar
  parking         String   // "Açık", "Kapalı", "Yok"
  facade          String   // "Güney", "Kuzey", "Doğu", "Batı" vb.
  hasElevator     Boolean
  isWithinSite    Boolean  @default(false)
  buildingCondition String @default("Standart") // "Masraflı", "Standart", "Yenilenmiş"

  // Algoritma / Yapay Zeka Sonuçları
  estimatedValue  Float
  aiComment       String?
  demographics    Json?
  visionAnalysis  Json?    // V2: Görüntü destekli otonom analiz sonucu
  
  // Admin CRM (V4)
  adminNote       String?  @db.Text
  overridenValue  Float?
  
  // Fiyat Geri Bildirim Sistemi (V28)
  priceFeedback   String?  // "YUKSEK", "NORMAL", "DUSUK"

  // İsteğe Bağlı Ödeme / Onay Altyapısı (V6)
  paymentStatus   Boolean  @default(true) // Şimdilik ücretsiz 

  // Yeni V19 Özelliği (Lead Market): Evini satmak/kiralamak istiyor mu?
  wantsToSell     Boolean  @default(false)

  // Güvenlik & Anti-Spam (V16)
  ipAddress       String?

  // Kurumsal B2B Emlakçı (V11)
  realtorId       String?
  realtor         Realtor? @relation(fields: [realtorId], references: [id], onDelete: SetNull)

  // Bireysel Yatırımcı Portföyü (Phase 3)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // İlişkili İletişim Bilgileri (Lead)
  contactInfo     ContactInfo?

  @@index([createdAt])
  @@index([ipAddress])
}

model ContactInfo {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  
  fullName             String
  phone                String
  email                String
  
  // Hukuki Onaylar
  kvkkApproved         Boolean  @default(false)
  aiDisclaimerApproved Boolean  @default(false)

  // İlişki Kurulumu
  valuationRequestId   String   @unique
  valuationRequest     ValuationRequest @relation(fields: [valuationRequestId], references: [id], onDelete: Cascade)
}

model City {
  id        String     @id @default(cuid())
  name      String     @unique
  districts District[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model District {
  id            String         @id @default(cuid())
  name          String
  cityId        String
  city          City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  neighborhoods Neighborhood[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([name, cityId])
}

model Neighborhood {
  id         String   @id @default(cuid())
  name       String
  multiplier Float    @default(1.0)
  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, districtId])
}

model AlgorithmSettings {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String   @db.Text
  description     String?
  updatedAt       DateTime @updatedAt
}

model Admin {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String?  @db.Text
  content     String   @db.Text
  imageUrl    String?  @db.Text
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Realtor {
  id              String   @id @default(cuid())
  companyName     String
  email           String   @unique
  password        String
  phone           String?
  
  // Abonelik Seviyesi (V19 PRO/PRO_PLUS)
  isPro           Boolean  @default(false) // Geriye dönük uyumluluk için tutulur.
  subscriptionTier SubscriptionTier @default(FREE)
  subscriptionEnd DateTime?
  
  // White-Label (Markalama) Özel Logosu
  customLogoUrl   String?  @db.Text
  
  valuations      ValuationRequest[]
  
  // Ödemeler (ParamPos B2B)
  payments        Payment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id              String   @id @default(cuid())
  amount          Float
  currency        String   @default("TRY")
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  transactionId   String?  @unique // ParamPos'tan dönen işlem ID'si
  errorMessage    String?  @db.Text
  
  // Hangi paket alındı
  tierPurchased   SubscriptionTier
  
  // Hangi Emlakçıya ait
  realtorId       String
  realtor         Realtor  @relation(fields: [realtorId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ValidationCode {
  id        String   @id @default(cuid())
  identifier String
  code      String
  expiresAt DateTime
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([identifier])
}

model SystemSettings {
  id               String   @id @default(cuid()) // Daima tek nesne dönecek şekilde tasarlanır
  instagramUrl     String?  
  twitterUrl       String?
  linkedinUrl      String?
  showSocialMedia  Boolean  @default(true)
  valuationCounter Int      @default(0)          // Sayaç Manipülasyonu
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  comment   String   @db.Text
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PHASE 3: PropTech Bloomberg Terminal
// ============================================

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String   @unique
  password        String
  phone           String?
  
  // B2C Abonelik veya Premium Satın Alımlar
  isPremium       Boolean  @default(false)
  
  // Kullanıcının Portföyüne Eklediği Kendi Evleri
  portfolio       ValuationRequest[]
  
  // Radardaki Favori / Fırsat İlanlar
  savedListings   SavedListing[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SavedListing {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // İlan verisi
  listingUrl      String?  @db.Text
  title           String?
  city            String
  district        String
  askingPrice     Float
  
  // Sistemimizin bu ilana biçtiği değer
  systemValuation Float
  
  // (systemValuation - askingPrice) / systemValuation -> Fırsat yüzdesi
  opportunityScore Float   @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RadarOpportunity {
  id              String   @id @default(cuid())
  
  title           String
  city            String
  district        String
  neighborhood    String
  
  askingPrice     Float
  estimatedValue  Float
  
  // Calculated manually or derived: (estimatedValue - askingPrice) / estimatedValue * 100
  discount        Float
  
  imageUrl        String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
